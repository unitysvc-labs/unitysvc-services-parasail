{
  "schema": "listing_v1",
  "time_created": "{{ time_created }}",
  "status": "{{ status | default('ready') }}",
  "currency": "USD",
{%- if list_price %}
  "list_price": {{ list_price | tojson }},
{%- endif %}
  "user_access_interfaces": {
    "provider_api": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/p/{{ provider_name }}",
      "routing_key": {"model": "{{ offering_name }}"}
    }
  },
  "documents": {
    "How to use this model": {
      "$doc_preset": "llm_description"
    },
    "Python code example": {
      "$doc_preset": {
        "name": "llm_code_example_openai",
        "description": "Example code to use the model"
      }
    },
    "Python function calling code example": {
      "category": "code_example",
      "description": "Example code to use the model",
      "file_path": "../../docs/code-example-fc.py.j2",
      "is_active": true,
      "is_public": true,
      "mime_type": "python"
    },
    "JavaScript code example": {
      "$doc_preset": {
        "name": "llm_code_example_javascript",
        "description": "Example code to use the model"
      }
    },
    "cURL code example": {
      "$doc_preset": {
        "name": "llm_code_example_shell",
        "description": "Example code to use the model"
      }
    },
    "Connectivity test": {
      "category": "connectivity_test",
      "description": "Connectivity test",
      "file_path": "../../docs/connectivity.sh.j2",
      "is_active": true,
      "is_public": false,
      "mime_type": "bash"
    }
  }
}
